{
	"id": "production-environment",
	"name": "Production",
	"values": [
		{
			"key": "api_gateway_url",
			"value": "http://{{ingress_ip}}",
			"type": "default",
			"enabled": true,
			"description": "API Gateway URL - same ingress for both staging and prod"
		},
		{
			"key": "ingress_ip",
			"value": "localhost:8080",
			"type": "default",
			"enabled": true,
			"description": "Istio Ingress Gateway IP (same as staging). Get with: kubectl get svc istio-ingressgateway -n istio-system -o jsonpath='{.status.loadBalancer.ingress[0].ip}'"
		},
		{
			"key": "host_header",
			"value": "api.ml-platform.example.com",
			"type": "default",
			"enabled": true,
			"description": "Host header for Istio VirtualService routing"
		},
		{
			"key": "predict_path",
			"value": "/predict",
			"type": "default",
			"enabled": true,
			"description": "Prediction endpoint path - /predict for production model"
		},
		{
			"key": "api_key",
			"value": "REPLACE_WITH_PROD_API_KEY",
			"type": "secret",
			"enabled": true,
			"description": "API Key for authentication (production key - keep secret!)"
		},
		{
			"key": "model_name",
			"value": "spam-detector",
			"type": "default",
			"enabled": true,
			"description": "Model name in KServe (production version)"
		},
		{
			"key": "environment_type",
			"value": "production",
			"type": "default",
			"enabled": true,
			"description": "Environment identifier"
		}
	],
	"_postman_variable_scope": "environment"
}
