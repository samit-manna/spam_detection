{
	"info": {
		"_postman_id": "spam-detection-api-collection",
		"name": "Spam Detection API",
		"description": "API collection for testing the ML-based Spam Detection platform.\n\n## Overview\n- Health check endpoints\n- Prediction endpoints (single and staging)\n- Test cases for spam and ham emails\n\n## Authentication\nAll requests require an `X-API-Key` header.\n\n## Host Header\nWhen using Istio ingress, include the `Host` header with the configured domain.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "{{api_gateway_url}}"
		}
	],
	"auth": {
		"type": "apikey",
		"apikey": [
			{
				"key": "key",
				"value": "X-API-Key",
				"type": "string"
			},
			{
				"key": "value",
				"value": "{{api_key}}",
				"type": "string"
			},
			{
				"key": "in",
				"value": "header",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is JSON\", function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test(\"Status is healthy or degraded\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(['healthy', 'degraded']).to.include(jsonData.status);",
									"});",
									"",
									"pm.test(\"Response time is acceptable\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(5000);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Host",
								"value": "{{host_header}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{api_gateway_url}}/health",
							"host": [
								"{{api_gateway_url}}"
							],
							"path": [
								"health"
							]
						},
						"description": "Check the health status of the API Gateway and its dependencies."
					},
					"response": []
				}
			],
			"description": "Health check endpoints for monitoring API availability."
		},
		{
			"name": "Predictions",
			"item": [
				{
					"name": "Predict - Spam Email (Lottery)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is JSON\", function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test(\"Has prediction field\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('prediction');",
									"});",
									"",
									"pm.test(\"Has spam_probability field\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('spam_probability');",
									"});",
									"",
									"pm.test(\"Prediction is spam\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.prediction).to.equal('spam');",
									"});",
									"",
									"pm.test(\"Spam probability is high (>0.5)\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.spam_probability).to.be.above(0.5);",
									"});",
									"",
									"pm.test(\"Response time is acceptable\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(10000);",
									"});"
								],
