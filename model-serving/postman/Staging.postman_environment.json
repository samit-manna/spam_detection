{
	"id": "staging-environment",
	"name": "Staging",
	"values": [
		{
			"key": "api_gateway_url",
			"value": "http://{{ingress_ip}}",
			"type": "default",
			"enabled": true,
			"description": "API Gateway URL - same ingress for both staging and prod"
		},
		{
			"key": "ingress_ip",
			"value": "localhost:8080",
			"type": "default",
			"enabled": true,
			"description": "Istio Ingress Gateway IP. Get with: kubectl get svc istio-ingressgateway -n istio-system -o jsonpath='{.status.loadBalancer.ingress[0].ip}'"
		},
		{
			"key": "host_header",
			"value": "api.ml-platform.example.com",
			"type": "default",
			"enabled": true,
			"description": "Host header for Istio VirtualService routing"
		},
		{
			"key": "predict_path",
			"value": "/predict/staging",
			"type": "default",
			"enabled": true,
			"description": "Prediction endpoint path - /predict/staging for staging model"
		},
		{
			"key": "api_key",
			"value": "test-operator-key",
			"type": "secret",
			"enabled": true,
			"description": "API Key for authentication (staging uses test key)"
		},
		{
			"key": "model_name",
			"value": "spam-detector-staging",
			"type": "default",
			"enabled": true,
			"description": "Model name in KServe (staging version)"
		},
		{
			"key": "environment_type",
			"value": "staging",
			"type": "default",
			"enabled": true,
			"description": "Environment identifier"
		}
	],
	"_postman_variable_scope": "environment"
}
